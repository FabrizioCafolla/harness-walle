---
// Story-only wrapper: Astrobook passes props, not slots, so this component
// provides sample slides for the Carousel stories.
import Carousel from "@walle/components/features/Carousel.astro";

interface Props {
  label?: string;
  perView?: 1 | 2 | 3 | 4;
  controls?: boolean;
  slides?: number;
}

const { label = "Demo carousel", perView = 1, controls = true, slides = 5 } = Astro.props;
---

<Carousel label={label} perView={perView} controls={controls}>
  {Array.from({ length: slides }, (_, i) => <div class="demo-slide">Slide {i + 1}</div>)}
</Carousel>

<style>
  .demo-slide {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 200px;
    background: var(--surface-alt, #f5f5f5);
    border: 1px solid var(--border, #d1d5db);
    border-radius: 0.75rem;
    font-size: 1.25rem;
    font-weight: 600;
  }
</style>
