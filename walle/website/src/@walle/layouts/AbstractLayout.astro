---
import { Analytics, Head, StructuredData } from "@walle/components";
import config from "@walle/config";
import { organizationJsonLd, websiteJsonLd } from "@walle/utils/structured-data";
import "@walle/styles/global.css";
// Generated theme tokens (overrides walle defaults, overridden by consumer global.css).
import "virtual:walle-theme.css";
import "@styles/global.css";

const {
  headerTitle = "",
  headerDescription = config.app.website.description || "",
  headerImage = config.app.website.image || null,
  headerOgImage = null,
  headerRobots = config.app.website.robots || "index, follow",
  headerLanguage = config.app.website.language || "",
  headerPublishedTime = null,
  skipLinkLabel = "Skip to content",
} = Astro.props;

const siteInfo = {
  title: config.app.website.title,
  description: config.app.website.description,
  url: Astro.site ? new URL(config.app.astro.basePath || "/", Astro.site).href : "",
  image: headerImage ? new URL(headerImage, Astro.site).href : undefined,
};
---

<!doctype html>
<html lang={headerLanguage}>
  <head>
    <Head
      title={headerTitle}
      description={headerDescription}
      image={headerImage}
      ogImage={headerOgImage}
      robots={headerRobots}
      publishedTime={headerPublishedTime}
    />
    <StructuredData data={[websiteJsonLd(siteInfo), organizationJsonLd(siteInfo)]} />
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">{skipLinkLabel}</a>
    <slot />
    <Analytics
      enable={config.env.IS_PRODUCTION || false}
      scriptContent={config.app.astro.analyticsScriptContent || ""}
    />
  </body>
</html>
