---
import config from "@walle/config";
import { resolveInternalUrl } from "@walle/utils";
import "@walle/styles/global.css";

interface Props {
  title: string;
  description: string;
  image?: string;
  ogImage?: string;
  robots?: string;
  favicon?: string;
  /**
   * Article publication timestamp — emits `article:published_time`
   */
  publishedTime?: Date | string | null;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
  title,
  description = config.app.website.description,
  image = config.app.website.image,
  ogImage,
  robots = null,
  favicon = config.app.website.favicon,
  publishedTime = null,
} = Astro.props;

const titleSeo = title + " | " + config.app.website.title;
const ogImageUrl = ogImage ?? new URL(image, Astro.url);
const resolvedFavicon = resolveInternalUrl(favicon);
// BCP 47 ("en-US") → Open Graph locale ("en_US")
const ogLocale = (config.app.website.language || "").replace("-", "_") || null;
const publishedIso = publishedTime ? new Date(publishedTime).toISOString() : null;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href={resolvedFavicon} />
<link rel="sitemap" href={resolveInternalUrl("/sitemap-index.xml")} />
<link
  rel="alternate"
  type="application/rss+xml"
  title={titleSeo}
  href={new URL("rss.xml", Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{titleSeo}</title>
<meta name="title" content={titleSeo} />
<meta name="description" content={description} />

{robots && <meta name="robots" content={robots} />}

<!-- Open Graph / Facebook -->
<meta property="og:type" content={publishedIso ? "article" : "website"} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={titleSeo} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />
{ogLocale && <meta property="og:locale" content={ogLocale} />}
{publishedIso && <meta property="article:published_time" content={publishedIso} />}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={titleSeo} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImageUrl} />
