---
import Image from "@walle/components/elements/Image.astro";
import Price from "@walle/components/elements/Price.astro";
import type { PriceData } from "@walle/components/elements/Price.astro";

/**
 * Product shape rendered by ProductCard and reused for Product JSON-LD.
 * Mirrors schema.org Product/Offer so one object feeds both the visible
 * card and the structured data. Headless-commerce providers map their
 * payload onto this shape in the consumer site.
 */
export interface ProductData {
  name: string;
  description?: string;
  image: {
    src: ImageMetadata | string;
    alt: string;
  };
  price: PriceData;
  availability?: "in_stock" | "out_of_stock" | "preorder";
  badge?: {
    text: string;
    variant?: "primary" | "secondary";
  };
  /**
   * Product detail page URL
   */
  href: string;
}

export interface Props {
  /**
   * Product to render
   */
  product: ProductData;

  /**
   * Availability labels (English defaults, override for localization)
   */
  availabilityLabels?: {
    out_of_stock?: string;
    preorder?: string;
  };

  /**
   * Additional CSS classes appended to the root element
   */
  class?: string;
}

const { product, availabilityLabels = {}, class: className = "" } = Astro.props;

const labels = {
  out_of_stock: availabilityLabels.out_of_stock ?? "Out of stock",
  preorder: availabilityLabels.preorder ?? "Preorder",
};

const availabilityText =
  product.availability && product.availability !== "in_stock" ? labels[product.availability] : null;

const classes = ["card", "product-card", className].filter(Boolean).join(" ");
---

<a href={product.href} class={classes} aria-label={product.name} data-component="ProductCard">
  <article class="product-card__wrapper">
    <div class="product-card__image">
      <Image image={product.image} width={480} height={480} ratio="1" />
      {availabilityText && <span class="product-card__availability">{availabilityText}</span>}
    </div>

    <div class="product-card__content">
      {
        product.badge && (
          <span
            class={`product-card__badge product-card__badge--${product.badge.variant || "primary"}`}
          >
            {product.badge.text}
          </span>
        )
      }
      <h3 class="product-card__name">{product.name}</h3>
      {product.description && <p class="product-card__description">{product.description}</p>}
      <Price price={product.price} />
    </div>
  </article>
</a>

<style>
  .product-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .product-card__wrapper {
    display: flex;
    flex-direction: column;
    height: 100%;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
    overflow: hidden;
    transition: var(--transition);
  }

  .product-card:hover .product-card__wrapper {
    border-color: var(--primary);
    box-shadow: var(--box-shadow-hover);
  }

  .product-card:focus-visible {
    outline: 3px solid var(--focus-ring);
    outline-offset: 3px;
  }

  .product-card__image {
    position: relative;
    background: var(--surface-alt);
  }

  .product-card__image :global(img) {
    width: 100%;
  }

  .product-card__availability {
    position: absolute;
    top: var(--space-sm);
    right: var(--space-sm);
    background: var(--text);
    color: var(--surface);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25em 0.75em;
    border-radius: var(--radius-sm);
  }

  .product-card__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-md);
    flex: 1;
  }

  .product-card__badge {
    align-self: flex-start;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.3em 0.8em;
    border-radius: var(--radius-sm);
  }

  .product-card__badge--primary {
    color: var(--primary);
    background: color-mix(in srgb, var(--primary) 10%, transparent);
  }

  .product-card__badge--secondary {
    color: var(--secondary);
    background: color-mix(in srgb, var(--secondary) 10%, transparent);
  }

  .product-card__name {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    margin: 0;
    line-height: 1.3;
  }

  .product-card:hover .product-card__name {
    color: var(--primary);
  }

  .product-card__description {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin: 0;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (prefers-reduced-motion: reduce) {
    .product-card__wrapper {
      transition: none;
    }
  }
</style>
