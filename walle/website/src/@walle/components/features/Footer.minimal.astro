---
// Minimal footer variant: single centered row, navigation links + copyright, no social/brand block.
// Selected via `components.footer = "minimal"` in app.json. Resolved by FooterResolver.astro.
import type { FooterConfig, NavigationLink } from "@walle/config";
import config from "@walle/config";
import { resolveInternalUrl } from "@walle/utils";

const footerConfig: FooterConfig = config.footer;
const today = new Date();
const items = Array.isArray(footerConfig.items) ? footerConfig.items : [];
const navigationLinks = items.filter((item: NavigationLink) => item.name);
const label = footerConfig.logo?.title || footerConfig.logo?.license || "";
---

<footer class="footer-minimal">
  <nav class="footer-minimal__nav" aria-label="Footer navigation">
    <ul>
      {
        navigationLinks.map((item: NavigationLink) => (
          <li>
            <a href={resolveInternalUrl(item.url)}>{item.name}</a>
          </li>
        ))
      }
    </ul>
  </nav>
  <span class="footer-minimal__license">{today.getFullYear()} &copy; {label}</span>
</footer>

<style>
  .footer-minimal {
    margin-top: auto;
    padding: 1.25rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    background-color: var(--gray);
    border-top: 1px solid #eaeaea;
    color: var(--gray-dark);
    font-size: 0.9rem;
  }

  .footer-minimal__nav ul {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-minimal__nav a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-minimal__nav a:hover {
    color: var(--primary);
  }

  .footer-minimal__license {
    font-size: 0.8rem;
    opacity: 0.8;
  }
</style>
